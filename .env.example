# LINE Developers コンソールで取得
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
LINE_CHANNEL_SECRET=your_channel_secret

# 画像の保存先フォルダ（省略時: images）
IMAGE_SAVE_DIR=images

# Flask のポート（5000 は他アプリと競合しやすいため 5001 推奨）
PORT=5001

# OCR結果を追記するCSV（Googleスプレッドシートにインポート可能）
OCR_OUTPUT_CSV=line_ocr_records.csv

# OCR言語（日本語+英語）
OCR_LANGUAGE=jpn+eng
# tesseractがPATHにない場合に実行ファイルを指定（Windows例）
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
# Herokuでは以下のパスを指定
# TESSERACT_CMD=/app/.apt/usr/bin/tesseract
# TESSDATA_PREFIX=/app/.apt/usr/share/tesseract-ocr/5/tessdata

# Googleスプレッドシート直接追記（未設定ならCSVのみ）
GOOGLE_SERVICE_ACCOUNT_JSON=google-service-account.json
# Herokuでは鍵JSONそのものを環境変数に入れる運用も可
# GOOGLE_SERVICE_ACCOUNT_JSON_CONTENT={"type":"service_account",...}
GOOGLE_SHEET_ID=1o-nncD_ot4tcoKj5IZxs_dyqI-H0SpsPMlOCc7Qm-Iw
GOOGLE_SHEET_NAME=シート1
